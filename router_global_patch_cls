def compute_per_class_metrics(cm: np.ndarray, class_names: List[str]) -> List[Dict[str, float]]:
    """
    For multiclass setting:
      recall_i = TP_i / (# true class i)
      class_accuracy here is defined the same way:
        correct predictions among true samples of class i
    """
    results = []
    total = int(cm.sum())

    for i, cls in enumerate(class_names):
        tp = int(cm[i, i])
        fn = int(cm[i, :].sum() - tp)
        fp = int(cm[:, i].sum() - tp)
        tn = int(total - tp - fn - fp)
        support = int(cm[i, :].sum())

        recall = tp / support if support > 0 else 0.0
        class_accuracy = recall

        results.append({
            "class_name": cls,
            "support": support,
            "tp": tp,
            "fp": fp,
            "fn": fn,
            "tn": tn,
            "recall": float(recall),
            "class_accuracy": float(class_accuracy),
        })

    return results


