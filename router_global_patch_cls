# =========================
# Tau gating evaluation
# =========================
def eval_good_gate(y_true_mult: np.ndarray, proba: np.ndarray, tau: float):
    """
    Gate to GOOD if p_good >= tau, else predict best defect class.
    Returns: (metrics_dict, cm_mult, y_pred_mult)
    """
    y_true_mult = np.asarray(y_true_mult, dtype=int)
    p_good = proba[:, 0]

    defect_pred = 1 + np.argmax(proba[:, 1:], axis=1)
    y_pred = defect_pred.copy()
    y_pred[p_good >= tau] = 0

    y_true_bin = (y_true_mult != 0).astype(int)
    defect_score = 1.0 - p_good

    out = {
        "tau": float(tau),
        "AUROC": float(roc_auc_score(y_true_bin, defect_score)),
        "AP": float(average_precision_score(y_true_bin, defect_score)),
        "Acc": float(accuracy_score(y_true_mult, y_pred)),
    }

    cm_bin = confusion_matrix(y_true_bin, (y_pred != 0).astype(int), labels=[0, 1])
    tn, fp, fn, tp = cm_bin.ravel()
    out["FPR_good"] = float(fp / (fp + tn + 1e-12))
    out["TPR_defect"] = float(tp / (tp + fn + 1e-12))

    cm_mult = confusion_matrix(y_true_mult, y_pred, labels=list(range(proba.shape[1])))
    return out, cm_mult, y_pred


def pick_tau_constraint_first(
    y_true_mult: np.ndarray,
    proba: np.ndarray,
    taus: np.ndarray,
    fpr_max: float,
) -> Tuple[float, Dict[str, float]]:
    """
    Constraint-first:
      - consider taus with FPR_good <= fpr_max
      - among them maximize TPR_defect
      - tie-breaker: Acc
    If none satisfy, fallback to best Acc.
    """
    best_by_acc = (-1.0, None)
    best_under = None

    for tau in taus:
        m, _, _ = eval_good_gate(y_true_mult, proba, tau=float(tau))

        if m["Acc"] > best_by_acc[0]:
            best_by_acc = (m["Acc"], m)

        if m["FPR_good"] <= fpr_max:
            cand = (m["TPR_defect"], m["Acc"], m)
            if (best_under is None) or (cand[0] > best_under[0]) or (cand[0] == best_under[0] and cand[1] > best_under[1]):
                best_under = cand

    if best_under is not None:
        return float(best_under[2]["tau"]), best_under[2]
    return float(best_by_acc[1]["tau"]), best_by_acc[1]


