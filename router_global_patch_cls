def compute_type_real_pred_table(
    type_id: np.ndarray,
    y_true: np.ndarray,
    y_pred: np.ndarray,
    class_names: List[str],
    k_types: int,
) -> List[Dict[str, Any]]:
    """
    For each router type, summarize:
      - total size
      - real class counts
      - predicted class counts
      - correct class counts
    """
    rows = []
    C = len(class_names)

    for t in range(k_types):
        idx = np.where(type_id == t)[0]
        row: Dict[str, Any] = {
            "type_id": int(t),
            "size": int(len(idx)),
        }

        if len(idx) == 0:
            for cls in class_names:
                row[f"real_{cls}"] = 0
                row[f"pred_{cls}"] = 0
                row[f"correct_{cls}"] = 0
            row["n_correct_total"] = 0
            row["acc_within_type"] = 0.0
            rows.append(row)
            continue

        yt = y_true[idx]
        yp = y_pred[idx]

        n_correct_total = 0
        for c, cls in enumerate(class_names):
            real_count = int(np.sum(yt == c))
            pred_count = int(np.sum(yp == c))
            correct_count = int(np.sum((yt == c) & (yp == c)))

            row[f"real_{cls}"] = real_count
            row[f"pred_{cls}"] = pred_count
            row[f"correct_{cls}"] = correct_count

            n_correct_total += correct_count

        row["n_correct_total"] = int(n_correct_total)
        row["acc_within_type"] = float(n_correct_total / len(idx))
        rows.append(row)

    return rows

def save_type_real_pred_table(
    out_path: Path,
    rows: List[Dict[str, Any]],
    class_names: List[str],
):
    out_path.parent.mkdir(parents=True, exist_ok=True)

    fieldnames = ["type_id", "size"]
    fieldnames += [f"real_{cls}" for cls in class_names]
    fieldnames += [f"pred_{cls}" for cls in class_names]
    fieldnames += [f"correct_{cls}" for cls in class_names]
