def pool_patch_tokens(tokens_2d_or_3d: np.ndarray, method: str = "mean", topk: int = 64) -> np.ndarray:
    """
    tokens_2d_or_3d: (P,D) or (N,P,D)
    returns:
      - if input is (P,D): (D') vector
      - if input is (N,P,D): (N,D') matrix
    """
    if tokens_2d_or_3d.ndim == 2:
        T = tokens_2d_or_3d[None, ...]
        one = True
    elif tokens_2d_or_3d.ndim == 3:
        T = tokens_2d_or_3d
        one = False
    else:
        raise ValueError(f"Expected (P,D) or (N,P,D), got {tokens_2d_or_3d.shape}")

    N, P, D = T.shape

    if method == "mean":
        out = T.mean(axis=1)
    elif method == "max":
        out = T.max(axis=1)
    elif method == "meanmax":
        out = np.concatenate([T.mean(axis=1), T.max(axis=1)], axis=1)
    else:
        norms = np.linalg.norm(T, axis=2)  # (N,P)
        k = min(topk, P)
        idx = np.argpartition(norms, -k, axis=1)[:, -k:]
        rows = np.arange(N)[:, None]
        topk_tokens = T[rows, idx, :]
        topk_mean = topk_tokens.mean(axis=1)

        if method == "topkmean":
            out = topk_mean
        elif method == "topkmeanmax":
            out = np.concatenate([topk_mean, T.max(axis=1)], axis=1)
        else:
            raise ValueError(f"Unknown PATCH_POOL={method}")

    return out[0] if one else out


def load_npz_one(npz_path: Path, forced_key: Optional[str] = None) -> np.ndarray:
    """
    Return patch tokens as (P,D).
    """
    if not npz_path.exists():
        raise FileNotFoundError(f"Missing patch npz: {npz_path}")

    data = np.load(npz_path, allow_pickle=True)
    keys = list(data.keys())
    if len(keys) == 0:
        raise ValueError(f"Empty npz: {npz_path}")

    if forced_key is not None:
        if forced_key not in data:
            raise KeyError(f"Key '{forced_key}' not in {npz_path}, keys={keys}")
        arr = data[forced_key]
    else:
        preferred = ["patch_tokens", "tokens", "patch", "x", "arr_0", "features"]
        key_use = None
        for k in preferred:
            if k in data:
                key_use = k
                break
        if key_use is None:
            best_k, best_size = None, -1
            for k in keys:
                a = np.array(data[k])
                size = int(np.prod(a.shape))
                if size > best_size:
                    best_size, best_k = size, k
            key_use = best_k
        arr = data[key_use]

    arr = np.array(arr)
    if arr.ndim == 3 and arr.shape[0] == 1:
        arr = arr[0]
    if arr.ndim != 2:
        raise ValueError(f"Expected (P,D) in {npz_path}, got {arr.shape}")
    return arr


