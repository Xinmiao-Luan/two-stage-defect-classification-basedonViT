def l2norm(X: np.ndarray, eps: float = 1e-12) -> np.ndarray:
    return X / (np.linalg.norm(X, axis=1, keepdims=True) + eps)

def float_to_str(x: float) -> str:
    s = f"{x:.10f}".rstrip("0").rstrip(".")
    return s if s != "" else "0"

def alpha_to_str(alpha: float) -> str:
    """
    Stable folder/file-safe string for alpha.
    Examples:
      0.0  -> 0
      0.3  -> 0.3
      1.5  -> 1.5
      2.0  -> 2
    """
    s = f"{alpha:.10f}".rstrip("0").rstrip(".")
    return s if s != "" else "0"

def compute_router_confidence_scores(X: np.ndarray, km: KMeans) -> Dict[str, np.ndarray]:
    """
    Compute router confidence scores from distances to KMeans centers.

    Returns:
      assigned_type      : argmin distance
      d_min             : distance to nearest center
      d_second          : distance to second nearest center
      margin            : d_second - d_min
      norm_margin       : (d_second - d_min) / (d_second + 1e-12)
      softmax_conf      : max soft assignment probability based on exp(-distance)
      entropy           : entropy of soft assignment (higher = more ambiguous)
      top2_ratio        : d_min / (d_second + 1e-12)   smaller = more confident
    """
    # distances: (N, K)
    D = km.transform(X)

    # order distances
    order = np.argsort(D, axis=1)
    assigned_type = order[:, 0]

    row_idx = np.arange(D.shape[0])
    d_min = D[row_idx, order[:, 0]]
    d_second = D[row_idx, order[:, 1]] if D.shape[1] >= 2 else d_min.copy()

    margin = d_second - d_min
    norm_margin = margin / (d_second + 1e-12)
    top2_ratio = d_min / (d_second + 1e-12)

    # pseudo-probabilities from distances
    # subtract row min for numerical stability
    logits = -D
    logits = logits - logits.max(axis=1, keepdims=True)
    exp_logits = np.exp(logits)
    probs = exp_logits / (exp_logits.sum(axis=1, keepdims=True) + 1e-12)

    softmax_conf = probs.max(axis=1)
    entropy = -np.sum(probs * np.log(probs + 1e-12), axis=1)

    return {
        "assigned_type": assigned_type.astype(int),
        "d_min": d_min.astype(float),
        "d_second": d_second.astype(float),
        "margin": margin.astype(float),
        "norm_margin": norm_margin.astype(float),
        "softmax_conf": softmax_conf.astype(float),
        "entropy": entropy.astype(float),
        "top2_ratio": top2_ratio.astype(float),
        "all_distances": D.astype(float),
        "soft_probs": probs.astype(float),
    }

def save_router_confidence_csv(
    out_path: Path,
    meta_rows,
    split_name: str,
    y_true: np.ndarray,
    conf: Dict[str, np.ndarray],
    class_names: List[str],
):
    out_path.parent.mkdir(parents=True, exist_ok=True)

    K = conf["all_distances"].shape[1]

    header = [
        "split",
        "source",
        "filename",
        "filepath",
        "global_idx",
        "true_class",
        "assigned_type",
        "d_min",
        "d_second",
        "margin",
        "norm_margin",
        "top2_ratio",
        "softmax_conf",
        "entropy",
    ]
    header += [f"dist_type_{k}" for k in range(K)]
    header += [f"prob_type_{k}" for k in range(K)]

    with open(out_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(header)

        for i, row in enumerate(meta_rows):
            out = [
                split_name,
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                class_names[int(y_true[i])],
                int(conf["assigned_type"][i]),
                float(conf["d_min"][i]),
                float(conf["d_second"][i]),
                float(conf["margin"][i]),
                float(conf["norm_margin"][i]),
                float(conf["top2_ratio"][i]),
                float(conf["softmax_conf"][i]),
                float(conf["entropy"][i]),
            ]
            out += list(map(float, conf["all_distances"][i]))
            out += list(map(float, conf["soft_probs"][i]))
            w.writerow(out)

def save_router_hard_samples_csv(
    out_path: Path,
    meta_rows,
    split_name: str,
    y_true: np.ndarray,
    conf: Dict[str, np.ndarray],
    class_names: List[str],
    top_n: int = 200,
    sort_by: str = "softmax_conf",
):
    """
    Export the hardest router decisions.

    sort_by:
      - "softmax_conf" ascending -> lower confidence is harder
      - "margin" ascending       -> smaller nearest-second gap is harder
      - "entropy" descending     -> higher entropy is harder
    """
    out_path.parent.mkdir(parents=True, exist_ok=True)

    N = len(y_true)
    idx = np.arange(N)

    if sort_by == "softmax_conf":
        idx = idx[np.argsort(conf["softmax_conf"])]          # low conf first
    elif sort_by == "margin":
        idx = idx[np.argsort(conf["margin"])]                # small gap first
    elif sort_by == "entropy":
        idx = idx[np.argsort(-conf["entropy"])]              # high entropy first
    else:
        raise ValueError("sort_by must be one of: softmax_conf, margin, entropy")

    idx = idx[:min(top_n, len(idx))]

    with open(out_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "rank",
            "split",
            "source",
            "filename",
            "filepath",
            "global_idx",
            "true_class",
            "assigned_type",
            "d_min",
            "d_second",
            "margin",
            "norm_margin",
            "top2_ratio",
            "softmax_conf",
            "entropy",
        ])

        for rank, i in enumerate(idx, start=1):
            row = meta_rows[i]
            w.writerow([
                rank,
                split_name,
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                class_names[int(y_true[i])],
                int(conf["assigned_type"][i]),
                float(conf["d_min"][i]),
                float(conf["d_second"][i]),
                float(conf["margin"][i]),
                float(conf["norm_margin"][i]),
                float(conf["top2_ratio"][i]),
                float(conf["softmax_conf"][i]),
                float(conf["entropy"][i]),
            ])

def get_manual_review_mask_from_router_conf(
    conf: Dict[str, np.ndarray],
    mode: str = "threshold",
    score_name: str = "softmax_conf",
    threshold: float = 0.35,
    top_n: int = 200,
) -> np.ndarray:
    """
    Returns boolean mask of samples to be sent to manual review.
    True = exclude from automatic pipeline.

    score_name:
      - "softmax_conf": smaller = harder
      - "margin":       smaller = harder
      - "entropy":      larger  = harder
    """
    if score_name not in {"softmax_conf", "margin", "entropy"}:
        raise ValueError("score_name must be one of: softmax_conf, margin, entropy")

    score = np.asarray(conf[score_name], dtype=float)
    n = len(score)

    if mode == "threshold":
        if score_name in {"softmax_conf", "margin"}:
            # low score = hard
            return score < threshold
        else:
            # entropy high = hard
            return score > threshold

    if mode == "top_n":
        mask = np.zeros(n, dtype=bool)

        if score_name in {"softmax_conf", "margin"}:
            # smallest values are hardest
            idx = np.argsort(score)
        else:
            # largest entropy values are hardest
            idx = np.argsort(-score)

        mask[idx[:min(top_n, n)]] = True
        return mask

    raise ValueError("mode must be 'threshold' or 'top_n'")

