def evaluate_with_exclusion(
    y_true_mult: np.ndarray,
    y_pred_mult: np.ndarray,
    proba: np.ndarray,
    exclude_mask: np.ndarray,
    class_names: List[str],
):
    """
    Evaluate classifier after excluding manual-review samples.
    """
    keep_mask = ~exclude_mask

    y_true_keep = y_true_mult[keep_mask]
    y_pred_keep = y_pred_mult[keep_mask]
    proba_keep = proba[keep_mask]

    if len(y_true_keep) == 0:
        raise ValueError("All samples were excluded; no samples left for evaluation.")

    y_true_bin_keep = (y_true_keep != 0).astype(int)
    defect_score_keep = 1.0 - proba_keep[:, 0]

    auroc_keep = float(roc_auc_score(y_true_bin_keep, defect_score_keep))
    ap_keep = float(average_precision_score(y_true_bin_keep, defect_score_keep))
    acc_keep = float(accuracy_score(y_true_keep, y_pred_keep))
    cm_keep = confusion_matrix(
        y_true_keep,
        y_pred_keep,
        labels=list(range(len(class_names)))
    )

    return {
        "n_total": int(len(y_true_mult)),
        "n_excluded": int(np.sum(exclude_mask)),
        "n_kept": int(np.sum(keep_mask)),
        "exclude_rate": float(np.mean(exclude_mask)),
        "AUROC_excluded": auroc_keep,
        "AP_excluded": ap_keep,
        "Acc_excluded": acc_keep,
        "cm_excluded": cm_keep,
        "y_true_keep": y_true_keep,
        "y_pred_keep": y_pred_keep,
        "keep_mask": keep_mask,
    }

