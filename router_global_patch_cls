def save_router_class_type_matrix(
    out_dir: Path,
    y_true: np.ndarray,
    type_id: np.ndarray,
    class_names: List[str],
    k_types: int
) -> np.ndarray:
    """
    Save contingency table:
      rows = true image class
      cols = router type_id
    """
    out_dir.mkdir(parents=True, exist_ok=True)

    mat = np.zeros((len(class_names), k_types), dtype=int)
    for y, t in zip(y_true, type_id):
        mat[int(y), int(t)] += 1

    csv_path = out_dir / "router_class_vs_type_matrix.csv"
    with open(csv_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["class\\type"] + [f"type_{k}" for k in range(k_types)])
        for i, row in enumerate(mat):
            w.writerow([class_names[i]] + list(map(int, row)))

    txt_path = out_dir / "router_class_vs_type_matrix.txt"
    with open(txt_path, "w") as f:
        f.write("Rows=true class, Cols=router type\n")
        f.write("Class order:\n")
        f.write(", ".join(class_names) + "\n\n")
        f.write(np.array2string(mat, separator=", "))

    return mat


def compute_router_type_metrics(mat: np.ndarray, class_names: List[str]) -> List[Dict[str, Any]]:
    """
    For each router type (cluster), compute:
      - size
      - dominant class
      - purity
      - class distribution
    mat shape = (num_classes, num_types)
    """
    num_classes, num_types = mat.shape
    results = []

    for t in range(num_types):
        col = mat[:, t]
        size = int(col.sum())

        if size == 0:
            dominant_class = "EMPTY"
            dominant_count = 0
            purity = 0.0
        else:
            dom_idx = int(np.argmax(col))
            dominant_class = class_names[dom_idx]
            dominant_count = int(col[dom_idx])
            purity = dominant_count / size

        row = {
            "type_id": t,
            "size": size,
            "dominant_class": dominant_class,
            "dominant_count": dominant_count,
            "purity": float(purity),
        }

        for i, cls in enumerate(class_names):
            row[f"count_{cls}"] = int(mat[i, t])

        results.append(row)

    return results


def save_router_type_metrics(out_dir: Path, metrics: List[Dict[str, Any]], class_names: List[str]):
    out_dir.mkdir(parents=True, exist_ok=True)

    fieldnames = ["type_id", "size", "dominant_class", "dominant_count", "purity"] + [f"count_{c}" for c in class_names]

    csv_path = out_dir / "router_type_metrics.csv"
    with open(csv_path, "w", newline="") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames)
        w.writeheader()
        for row in metrics:
            w.writerow(row)

    txt_path = out_dir / "router_type_metrics.txt"
    with open(txt_path, "w") as f:
        f.write("Router type metrics\n")
        f.write("=" * 80 + "\n")
        for row in metrics:
            f.write(
                f"type_{row['type_id']:2d}  "
                f"size={row['size']:4d}  "
                f"dominant={row['dominant_class']:10s}  "
                f"purity={row['purity']:.4f}\n"
            )


def compute_router_majority_vote_accuracy(
    y_true: np.ndarray,
    type_id: np.ndarray,
    mat: np.ndarray
) -> Tuple[float, np.ndarray, Dict[int, int]]:
    """
    Map each router type to its dominant true class, then compute a pseudo-classification accuracy.
    This gives an interpretable router-only accuracy.
    """
    _, num_types = mat.shape
    type_to_class: Dict[int, int] = {}

    for t in range(num_types):
        col = mat[:, t]
        if col.sum() == 0:
            type_to_class[t] = 0
        else:
            type_to_class[t] = int(np.argmax(col))

    y_pred = np.array([type_to_class[int(t)] for t in type_id], dtype=int)
    acc = float((y_pred == y_true).mean())
    return acc, y_pred, type_to_class


