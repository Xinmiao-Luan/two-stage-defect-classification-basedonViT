# Classifier factory
# =========================
def make_classifier(backend: str, *, C_value: float, balanced: bool, seed: int) -> Any:
    backend = backend.lower().strip()

    if backend == "lr":
        kw = dict(max_iter=4000, n_jobs=-1, C=C_value, random_state=seed)
        kw["class_weight"] = "balanced" if balanced else None
        return LogisticRegression(**kw)

    if backend == "lgbm":
        if not _HAS_LGB:
            raise RuntimeError("LightGBM is not installed. Run: pip install lightgbm")
        cw = "balanced" if balanced else None
        return lgb.LGBMClassifier(
            objective="multiclass",
            num_class=len(CLASS_NAMES),
            n_estimators=600,
            learning_rate=0.05,
            num_leaves=63,
            max_depth=-1,
            subsample=0.9,
            colsample_bytree=0.9,
            reg_lambda=1.0,
            class_weight=cw,
            random_state=seed,
            n_jobs=-1,
        )

    raise ValueError(f"Unknown CLASSIFIER_BACKEND={backend!r}. Use 'lr' or 'lgbm'.")


def proba_to_global(model: Any, X_one: np.ndarray, Cn: int) -> np.ndarray:
    p_local = model.predict_proba(X_one)[0]
    if hasattr(model, "classes_"):
        cls_local = np.asarray(model.classes_, dtype=int)
        p_global = np.zeros(Cn, dtype=float)
        p_global[cls_local] = p_local
        return p_global

    if len(p_local) == Cn:
        return np.asarray(p_local, dtype=float)

    raise RuntimeError("Model does not expose classes_, cannot map local probs to global.")

def proba_to_global_defect_classes(model: Any, X_one: np.ndarray, defect_class_ids: List[int], Cn: int) -> np.ndarray:
    """
    Map defect-only classifier probabilities back to the full class space.
    The classifier is trained only on defect classes, e.g. [1,2,5,6,7,8].
    Output is length Cn, with class 0 (good) left as 0.
    """
    p_local = model.predict_proba(X_one)[0]
    p_global = np.zeros(Cn, dtype=float)

    if hasattr(model, "classes_"):
        cls_local = np.asarray(model.classes_, dtype=int)
        for c_local, p in zip(cls_local, p_local):
            p_global[int(c_local)] = float(p)
    else:
        # fallback: assume order follows defect_class_ids
        for c_global, p in zip(defect_class_ids, p_local):
            p_global[int(c_global)] = float(p)

    return p_global
# =========================
# Load once
# =========================
def load_global_and_patch_features() -> Tuple[np.ndarray, np.ndarray, np.ndarray, list]:
    Xg_list = []
    Xp_list = []
    ys = []
    meta = []
    global_idx = 0

    for cls in CLASS_NAMES:
        emb_path = GLOBAL_EMB_DIR / f"{cls}.npy"
        img_dir = DATA_ROOT / cls
        patch_dir = PATCH_ROOT / cls

        if not emb_path.exists():
            raise FileNotFoundError(f"Missing global embedding: {emb_path}")
        if not img_dir.is_dir():
            raise FileNotFoundError(f"Missing image folder: {img_dir}")
        if not patch_dir.is_dir():
            raise FileNotFoundError(f"Missing patch folder: {patch_dir}")

        Xg = np.load(emb_path)
        files = sorted(os.listdir(img_dir))
        if len(files) != len(Xg):
            raise ValueError(f"Mismatch in {cls}: files={len(files)} global={len(Xg)}")

        pooled_list = []
        for fn in files:
            stem = Path(fn).stem
            npz_path = patch_dir / f"{stem}.npz"
            tokens = load_npz_one(npz_path, forced_key=PATCH_NPZ_KEY)
            pooled = pool_patch_tokens(tokens, method=PATCH_POOL, topk=PATCH_TOPK)
            pooled_list.append(pooled)

            meta.append({
                "source": cls,
                "filename": fn,
                "filepath": os.path.join(cls, fn),
                "global_idx": global_idx
            })
            global_idx += 1

        Xp = np.stack(pooled_list, axis=0)

        Xg_list.append(Xg)
        Xp_list.append(Xp)
        ys.append(np.full(len(Xg), name2id[cls], dtype=int))

        print(f"[Loaded] {cls}: global={Xg.shape}, patch_pooled={Xp.shape}")

    X_global = np.concatenate(Xg_list, axis=0)
    X_patch = np.concatenate(Xp_list, axis=0)
    y_mult = np.concatenate(ys, axis=0)
    return X_global, X_patch, y_mult, meta


def build_features_with_alpha(X_global: np.ndarray, X_patch: np.ndarray, alpha: float):
    """
    Router always uses normalized global embeddings (X_router).
    Classifier uses:
      - if alpha==0: X_cls = Xg
      - else:        X_cls = [Xg || alpha*Xp]
    """
    Xg = l2norm(X_global)
    Xp = l2norm(X_patch)

    if float(alpha) == 0.0:
        X_cls = Xg
    else:
        X_cls = np.concatenate([Xg, alpha * Xp], axis=1)

    return Xg, X_cls


# =========================
# One run
# =========================
def run_one_alpha(
    alpha: float,
    k_types: int,
    c_value: float,
    X_router,
    X_cls,
    y_mult,
    meta,
    tr,
    te,
    out_dir: Path
) -> Dict:
    out_dir.mkdir(parents=True, exist_ok=True)

    y_bin = (y_mult != 0).astype(int)

    Xr_tr = X_router[tr]
    Xc_tr, Xc_te_full = X_cls[tr], X_cls[te]
    y_tr_mult, y_te_mult_full = y_mult[tr], y_mult[te]
    y_tr_bin, y_te_bin_full = y_bin[tr], y_bin[te]

    # -----------------------
    # Router (KMeans on GOOD-train only)
    # -----------------------
    X_good_tr = Xr_tr[y_tr_mult == 0]

    if X_good_tr.shape[0] < 2:
        raise ValueError(f"#GOOD_train too small: {X_good_tr.shape[0]}")

    if k_types > X_good_tr.shape[0]:
        if CLAMP_K_TO_GOOD_TRAIN:
            print(f"[Warn] K_TYPES={k_types} > #GOOD_train={X_good_tr.shape[0]} -> clamped")
            k_types = int(X_good_tr.shape[0])
        else:
            raise ValueError(f"K_TYPES={k_types} > #GOOD_train={X_good_tr.shape[0]}")

    km = KMeans(n_clusters=k_types, random_state=SEED, n_init="auto").fit(X_good_tr)

    type_all = km.predict(X_router)
    type_tr = type_all[tr]
    type_te_full = type_all[te]

    split_all = np.array(["train"] * len(y_mult), dtype=object)
    split_all[te] = "test"
    export_types_csv(out_dir / "type_assignments.csv", meta, split_all, type_all)

    # -----------------------
    # Router confidence export
    # -----------------------
    router_eval_dir = out_dir / "router_eval"

    conf_tr = compute_router_confidence_scores(X_router[tr], km)
    conf_te = compute_router_confidence_scores(X_router[te], km)

    meta_tr = [meta[i] for i in tr]
    meta_te = [meta[i] for i in te]

    save_router_confidence_csv(
        router_eval_dir / "train" / "router_confidence_scores.csv",
        meta_tr,
        "train",
        y_tr_mult,
        conf_tr,
        CLASS_NAMES,
    )

    save_router_confidence_csv(
        router_eval_dir / "test" / "router_confidence_scores.csv",
        meta_te,
        "test",
        y_te_mult_full,
        conf_te,
        CLASS_NAMES,
    )

    save_router_hard_samples_csv(
        router_eval_dir / "train" / f"router_hard_samples_by_{ROUTER_CONFIDENCE_SCORE}.csv",
        meta_tr,
        "train",
        y_tr_mult,
        conf_tr,
        CLASS_NAMES,
        top_n=ROUTER_HARD_TOP_N,
        sort_by=ROUTER_CONFIDENCE_SCORE,
    )

    save_router_hard_samples_csv(
        router_eval_dir / "test" / f"router_hard_samples_by_{ROUTER_CONFIDENCE_SCORE}.csv",
        meta_te,
        "test",
        y_te_mult_full,
        conf_te,
        CLASS_NAMES,
        top_n=ROUTER_HARD_TOP_N,
        sort_by=ROUTER_CONFIDENCE_SCORE,
    )

    # 保留另外两种导出，方便分析
    if ROUTER_CONFIDENCE_SCORE != "softmax_conf":
        save_router_hard_samples_csv(
            router_eval_dir / "test" / "router_hard_samples_by_softmax_conf.csv",
            meta_te, "test", y_te_mult_full, conf_te, CLASS_NAMES,
            top_n=ROUTER_HARD_TOP_N, sort_by="softmax_conf"
        )
    if ROUTER_CONFIDENCE_SCORE != "margin":
        save_router_hard_samples_csv(
            router_eval_dir / "test" / "router_hard_samples_by_margin.csv",
            meta_te, "test", y_te_mult_full, conf_te, CLASS_NAMES,
            top_n=ROUTER_HARD_TOP_N, sort_by="margin"
        )
    if ROUTER_CONFIDENCE_SCORE != "entropy":
        save_router_hard_samples_csv(
            router_eval_dir / "test" / "router_hard_samples_by_entropy.csv",
            meta_te, "test", y_te_mult_full, conf_te, CLASS_NAMES,
            top_n=ROUTER_HARD_TOP_N, sort_by="entropy"
        )

    print(
        f"[Router {ROUTER_CONFIDENCE_SCORE} stats] "
        f"min={conf_te[ROUTER_CONFIDENCE_SCORE].min():.6f} "
        f"p5={np.percentile(conf_te[ROUTER_CONFIDENCE_SCORE], 5):.6f} "
        f"p25={np.percentile(conf_te[ROUTER_CONFIDENCE_SCORE], 25):.6f} "
        f"median={np.median(conf_te[ROUTER_CONFIDENCE_SCORE]):.6f} "
        f"p75={np.percentile(conf_te[ROUTER_CONFIDENCE_SCORE], 75):.6f} "
        f"max={conf_te[ROUTER_CONFIDENCE_SCORE].max():.6f}"
    )

    # -----------------------
    # Router evaluation (full test set)
    # -----------------------
    mat_tr = save_router_class_type_matrix(
        router_eval_dir / "train",
        y_tr_mult,
        type_tr,
        CLASS_NAMES,
        k_types
    )
    metrics_tr = compute_router_type_metrics(mat_tr, CLASS_NAMES)
    save_router_type_metrics(router_eval_dir / "train", metrics_tr, CLASS_NAMES)

    router_acc_tr, y_pred_router_tr, type_to_class_tr = compute_router_majority_vote_accuracy(
        y_tr_mult, type_tr, mat_tr
    )
    save_router_majority_vote_results(
        router_eval_dir / "train",
        y_tr_mult,
        y_pred_router_tr,
        type_to_class_tr,
        CLASS_NAMES,
        split_name="train"
    )

    mat_te = save_router_class_type_matrix(
        router_eval_dir / "test",
        y_te_mult_full,
        type_te_full,
        CLASS_NAMES,
        k_types
    )
    metrics_te = compute_router_type_metrics(mat_te, CLASS_NAMES)
    save_router_type_metrics(router_eval_dir / "test", metrics_te, CLASS_NAMES)

    router_acc_te, y_pred_router_te, type_to_class_te = compute_router_majority_vote_accuracy(
        y_te_mult_full, type_te_full, mat_te
    )
    save_router_majority_vote_results(
        router_eval_dir / "test",
        y_te_mult_full,
        y_pred_router_te,
        type_to_class_te,
        CLASS_NAMES,
        split_name="test"
    )

    router_mean_purity_tr = float(np.mean([m["purity"] for m in metrics_tr])) if len(metrics_tr) else 0.0
    router_mean_purity_te = float(np.mean([m["purity"] for m in metrics_te])) if len(metrics_te) else 0.0

    total_size_tr = max(1, np.sum([m["size"] for m in metrics_tr]))
    total_size_te = max(1, np.sum([m["size"] for m in metrics_te]))

    router_weighted_purity_tr = float(np.sum([m["purity"] * m["size"] for m in metrics_tr]) / total_size_tr)
    router_weighted_purity_te = float(np.sum([m["purity"] * m["size"] for m in metrics_te]) / total_size_te)

    # -----------------------
    # Manual-review exclusion BEFORE classification
    # -----------------------
    if ENABLE_MANUAL_REVIEW_EXCLUSION:
        manual_review_mask = get_manual_review_mask_from_router_conf(
            conf_te,
            mode=MANUAL_REVIEW_MODE,
            score_name=ROUTER_CONFIDENCE_SCORE,
            threshold=ROUTER_CONFIDENCE_THRESHOLD,
            top_n=ROUTER_HARD_TOP_N,
        )
    else:
        manual_review_mask = np.zeros(len(te), dtype=bool)

    keep_mask = ~manual_review_mask

    n_total_test = int(len(te))
    n_manual_review = int(np.sum(manual_review_mask))
    n_kept_test = int(np.sum(keep_mask))
    manual_review_rate = float(n_manual_review / max(1, n_total_test))

    dummy_pred_for_review = np.zeros(len(te), dtype=int)
    save_manual_review_samples_csv(
        out_dir / "manual_review_samples_test.csv",
        meta_te,
        y_te_mult_full,
        dummy_pred_for_review,
        type_te_full,
        conf_te,
        CLASS_NAMES,
        manual_review_mask,
        split_name="test",
    )

    if n_kept_test == 0:
        raise ValueError("All test samples were routed to manual review; no samples left for classification.")

    # kept test subset only
    Xc_te = Xc_te_full[keep_mask]
    y_te_mult = y_te_mult_full[keep_mask]
    y_te_bin = y_te_bin_full[keep_mask]
    type_te = type_te_full[keep_mask]
    meta_te_kept = [meta_te[i] for i in np.where(keep_mask)[0]]
    conf_te_kept = {k: v[keep_mask] for k, v in conf_te.items()}

    # -----------------------
    # Train classifiers
    # -----------------------
    stats: Dict[int, int] = {}

    if USE_HIERARCHICAL_CLASSIFICATION:
        # ===== hierarchical =====
        bin_clf_global = make_classifier(
            CLASSIFIER_BACKEND,
            C_value=c_value,
            balanced=USE_BALANCED,
            seed=SEED
        )
        bin_clf_global.fit(Xc_tr, y_tr_bin)

        defect_train_idx_global = np.where(y_tr_mult != 0)[0]
        if len(defect_train_idx_global) == 0:
            raise ValueError("No defect samples in training set.")

        def_clf_global = make_classifier(
            CLASSIFIER_BACKEND,
            C_value=c_value,
            balanced=False,
            seed=SEED
        )
        def_clf_global.fit(Xc_tr[defect_train_idx_global], y_tr_mult[defect_train_idx_global])

        bin_clfs: Dict[int, Any] = {}
        def_clfs: Dict[int, Any] = {}
        defect_stats: Dict[int, int] = {}

        for k in range(k_types):
            idx_k = np.where(type_tr == k)[0]
            n = int(len(idx_k))
            stats[k] = n

            if n >= MIN_SAMPLES_PER_TYPE:
                clf_bin_k = make_classifier(
                    CLASSIFIER_BACKEND,
                    C_value=c_value,
                    balanced=False,
                    seed=SEED
                )
                clf_bin_k.fit(Xc_tr[idx_k], y_tr_bin[idx_k])
                bin_clfs[k] = clf_bin_k

            idx_k_def = idx_k[y_tr_mult[idx_k] != 0]
            defect_stats[k] = int(len(idx_k_def))

            if len(idx_k_def) >= MIN_SAMPLES_PER_TYPE and len(np.unique(y_tr_mult[idx_k_def])) >= 2:
                clf_def_k = make_classifier(
                    CLASSIFIER_BACKEND,
                    C_value=c_value,
                    balanced=False,
                    seed=SEED
                )
                clf_def_k.fit(Xc_tr[idx_k_def], y_tr_mult[idx_k_def])
                def_clfs[k] = clf_def_k
    else:
        # ===== original single-stage multiclass =====
        clf_global = make_classifier(
            CLASSIFIER_BACKEND,
            C_value=c_value,
            balanced=USE_BALANCED,
            seed=SEED
        )
        clf_global.fit(Xc_tr, y_tr_mult)

        clfs: Dict[int, Any] = {}
        for k in range(k_types):
            idx_k = np.where(type_tr == k)[0]
            n = int(len(idx_k))
            stats[k] = n

            if n < MIN_SAMPLES_PER_TYPE:
                continue

            clf_k = make_classifier(
                CLASSIFIER_BACKEND,
                C_value=c_value,
                balanced=False,
                seed=SEED
            )
            clf_k.fit(Xc_tr[idx_k], y_tr_mult[idx_k])
            clfs[k] = clf_k

    # -----------------------
    # Predict on KEPT TEST samples
    # -----------------------
    Cn = len(CLASS_NAMES)
    proba = np.zeros((len(y_te_mult), Cn), dtype=float)
    pred_argmax = np.zeros(len(y_te_mult), dtype=int)

    if USE_HIERARCHICAL_CLASSIFICATION:
        # ===== hierarchical prediction =====
        for i in range(len(y_te_mult)):
            k = int(type_te[i])

            clf_bin = bin_clfs.get(k, bin_clf_global)
            p_bin_local = clf_bin.predict_proba(Xc_te[i:i+1])[0]

            p_good = 0.0
            p_defect = 0.0
            cls_bin = np.asarray(clf_bin.classes_, dtype=int)
            for cls_val, p in zip(cls_bin, p_bin_local):
                if int(cls_val) == 0:
                    p_good = float(p)
                elif int(cls_val) == 1:
                    p_defect = float(p)

            clf_def = def_clfs.get(k, def_clf_global)
            p_def_only = proba_to_global_defect_classes(
                clf_def,
                Xc_te[i:i+1],
                defect_class_ids=list(range(1, Cn)),
                Cn=Cn
            )

            p_full = np.zeros(Cn, dtype=float)
            p_full[0] = p_good

            defect_sum = p_def_only[1:].sum()
            if defect_sum > 0:
                p_full[1:] = p_defect * (p_def_only[1:] / defect_sum)
            else:
                p_full[1:] = p_defect / (Cn - 1)

            proba[i] = p_full
            pred_argmax[i] = int(np.argmax(p_full))
    else:
        # ===== original single-stage multiclass prediction =====
        for i in range(len(y_te_mult)):
            k = int(type_te[i])
            clf = clfs.get(k, clf_global)
            p_global = proba_to_global(clf, Xc_te[i:i+1], Cn=Cn)
            proba[i] = p_global
            pred_argmax[i] = int(np.argmax(p_global))

    # -----------------------
    # Base metrics (argmax) on kept samples only
    # -----------------------
    defect_score = 1.0 - proba[:, 0]
    auroc = float(roc_auc_score(y_te_bin, defect_score))
    ap = float(average_precision_score(y_te_bin, defect_score))
    acc = float(accuracy_score(y_te_mult, pred_argmax))
    cm = confusion_matrix(y_te_mult, pred_argmax, labels=list(range(Cn)))

    save_confusion_matrix(out_dir, cm)
    per_class_metrics = compute_per_class_metrics(cm, CLASS_NAMES)
    save_per_class_metrics(out_dir, per_class_metrics)

    excl_dir = out_dir / "excluding_manual_review"
    save_confusion_matrix(excl_dir, cm)
    save_per_class_metrics(excl_dir, per_class_metrics)

    with open(excl_dir / "exclusion_summary.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["metric", "value"])
        w.writerow(["n_total_test", n_total_test])
        w.writerow(["n_manual_review", n_manual_review])
        w.writerow(["n_kept_test", n_kept_test])
        w.writerow(["manual_review_rate", manual_review_rate])
        w.writerow(["auto_coverage", n_kept_test / max(1, n_total_test)])
        w.writerow(["router_confidence_score", ROUTER_CONFIDENCE_SCORE])
        w.writerow(["router_confidence_threshold", ROUTER_CONFIDENCE_THRESHOLD])
        w.writerow(["manual_review_mode", MANUAL_REVIEW_MODE])

    with open(out_dir / "test_predictions.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "source", "filename", "filepath", "global_idx",
            "type_id", "true_class", "pred_class",
            "p_good", "p_pred", "router_score"
        ])
        for i, row in enumerate(meta_te_kept):
            w.writerow([
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                int(type_te[i]),
                CLASS_NAMES[int(y_te_mult[i])],
                CLASS_NAMES[int(pred_argmax[i])],
                float(proba[i, 0]),
                float(proba[i, pred_argmax[i]]),
                float(conf_te_kept[ROUTER_CONFIDENCE_SCORE][i]),
            ])

    with open(excl_dir / "test_predictions_kept_only.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "source", "filename", "filepath", "global_idx",
            "type_id", "true_class", "pred_class",
            "p_good", "p_pred", "router_score"
        ])
        for i, row in enumerate(meta_te_kept):
            w.writerow([
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                int(type_te[i]),
                CLASS_NAMES[int(y_te_mult[i])],
                CLASS_NAMES[int(pred_argmax[i])],
                float(proba[i, 0]),
                float(proba[i, pred_argmax[i]]),
                float(conf_te_kept[ROUTER_CONFIDENCE_SCORE][i]),
            ])

    type_real_pred_rows = compute_type_real_pred_table(
        type_id=type_te,
        y_true=y_te_mult,
        y_pred=pred_argmax,
        class_names=CLASS_NAMES,
        k_types=k_types,
    )
    save_type_real_pred_table(out_dir / "type_real_vs_pred_table_test.csv", type_real_pred_rows, CLASS_NAMES)
    save_type_real_pred_table(excl_dir / "type_real_vs_pred_table_test.csv", type_real_pred_rows, CLASS_NAMES)

    save_typewise_confusion_matrices(
        out_dir / "typewise_confusion_test",
        type_te, y_te_mult, pred_argmax, CLASS_NAMES, k_types,
    )
    save_typewise_confusion_matrices(
        excl_dir / "typewise_confusion_test",
        type_te, y_te_mult, pred_argmax, CLASS_NAMES, k_types,
    )

    # -----------------------
    # Tau tuning on kept samples
    # -----------------------
    tau_csv = out_dir / "tau_sweep.csv"
    with open(tau_csv, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(["tau", "AUROC", "AP", "Acc", "FPR_good", "TPR_defect"])
        for tau in TAUS:
            m, _, _ = eval_good_gate(y_te_mult, proba, tau=float(tau))
            w.writerow([
                f"{m['tau']:.6f}",
                f"{m['AUROC']:.6f}",
                f"{m['AP']:.6f}",
                f"{m['Acc']:.6f}",
                f"{m['FPR_good']:.6f}",
                f"{m['TPR_defect']:.6f}",
            ])

    best_tau, best_tau_metrics = pick_tau_constraint_first(
        y_true_mult=y_te_mult,
        proba=proba,
        taus=TAUS,
        fpr_max=FPR_MAX_GLOBAL_TAU,
    )

    _, cm_best, pred_best_tau = eval_good_gate(y_te_mult, proba, tau=float(best_tau))
    best_dir = out_dir / f"best_tau_{best_tau:.4f}"
    best_excl_dir = excl_dir / f"best_tau_{best_tau:.4f}"

    save_confusion_matrix(best_dir, cm_best)
    save_per_class_metrics(best_dir, compute_per_class_metrics(cm_best, CLASS_NAMES))
    save_confusion_matrix(best_excl_dir, cm_best)
    save_per_class_metrics(best_excl_dir, compute_per_class_metrics(cm_best, CLASS_NAMES))

    with open(out_dir / "test_predictions_best_tau.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "source", "filename", "filepath", "global_idx",
            "type_id", "true_class", "pred_class",
            "p_good", "p_pred", "tau", "router_score"
        ])
        for i, row in enumerate(meta_te_kept):
            pred_i = int(pred_best_tau[i])
            w.writerow([
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                int(type_te[i]),
                CLASS_NAMES[int(y_te_mult[i])],
                CLASS_NAMES[pred_i],
                float(proba[i, 0]),
                float(proba[i, pred_i]),
                float(best_tau),
                float(conf_te_kept[ROUTER_CONFIDENCE_SCORE][i]),
            ])

    with open(best_excl_dir / "test_predictions_best_tau_kept_only.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "source", "filename", "filepath", "global_idx",
            "type_id", "true_class", "pred_class",
            "p_good", "p_pred", "tau", "router_score"
        ])
        for i, row in enumerate(meta_te_kept):
            pred_i = int(pred_best_tau[i])
            w.writerow([
                row["source"],
                row["filename"],
                row["filepath"],
                row["global_idx"],
                int(type_te[i]),
                CLASS_NAMES[int(y_te_mult[i])],
                CLASS_NAMES[pred_i],
                float(proba[i, 0]),
                float(proba[i, pred_i]),
                float(best_tau),
                float(conf_te_kept[ROUTER_CONFIDENCE_SCORE][i]),
            ])

    type_real_pred_rows_best_tau = compute_type_real_pred_table(
        type_id=type_te,
        y_true=y_te_mult,
        y_pred=pred_best_tau,
        class_names=CLASS_NAMES,
        k_types=k_types,
    )
    save_type_real_pred_table(out_dir / "type_real_vs_pred_table_test_best_tau.csv", type_real_pred_rows_best_tau, CLASS_NAMES)
    save_type_real_pred_table(best_excl_dir / "type_real_vs_pred_table_test_best_tau.csv", type_real_pred_rows_best_tau, CLASS_NAMES)

    save_typewise_confusion_matrices(
        best_dir / "typewise_confusion_test",
        type_te, y_te_mult, pred_best_tau, CLASS_NAMES, k_types,
    )
    save_typewise_confusion_matrices(
        best_excl_dir / "typewise_confusion_test",
        type_te, y_te_mult, pred_best_tau, CLASS_NAMES, k_types,
    )

    # -----------------------
    # Coverage / hybrid metrics
    # -----------------------
    auto_coverage = float(n_kept_test / max(1, n_total_test))
    correct_auto = int(np.sum(pred_argmax == y_te_mult))
    hybrid_accuracy = float((correct_auto + n_manual_review) / max(1, n_total_test))

    print(
        f"[Manual review] excluded={n_manual_review}/{n_total_test} "
        f"({manual_review_rate:.2%}), kept={n_kept_test}"
    )
    print(
        f"[Best tau (constraint-first, FPR<= {FPR_MAX_GLOBAL_TAU:.2%})] "
        f"tau={best_tau:.4f} Acc={best_tau_metrics['Acc']:.4f} "
        f"FPR_good={best_tau_metrics['FPR_good']:.4f} TPR_defect={best_tau_metrics['TPR_defect']:.4f}"
    )

    sizes = np.array([stats.get(k, 0) for k in range(k_types)], dtype=int) if k_types > 0 else np.array([], dtype=int)

    summary = {
        "CLASSIFIER_BACKEND": str(CLASSIFIER_BACKEND),
        "USE_BALANCED": int(bool(USE_BALANCED)),
        "UseHierarchicalClassification": int(bool(USE_HIERARCHICAL_CLASSIFICATION)),
        "alpha": float(alpha),
        "K_TYPES": int(k_types),
        "C_VALUE": float(c_value),
        "MIN_SAMPLES_PER_TYPE": int(MIN_SAMPLES_PER_TYPE),
        "PATCH_POOL": str(PATCH_POOL),
        "PATCH_TOPK": int(PATCH_TOPK),

        "X_global_dim": int(X_router.shape[1]),
        "X_cls_dim": int(X_cls.shape[1]),
        "X_patch_dim": int(X_cls.shape[1] - X_router.shape[1]) if X_cls.shape[1] >= X_router.shape[1] else 0,

        "RouterAccTrain": float(router_acc_tr),
        "RouterAccTest": float(router_acc_te),
        "RouterMeanPurityTrain": float(router_mean_purity_tr),
        "RouterMeanPurityTest": float(router_mean_purity_te),
        "RouterWeightedPurityTrain": float(router_weighted_purity_tr),
        "RouterWeightedPurityTest": float(router_weighted_purity_te),

        "ManualReviewEnabled": int(bool(ENABLE_MANUAL_REVIEW_EXCLUSION)),
        "ManualReviewMode": str(MANUAL_REVIEW_MODE),
        "RouterConfidenceScore": str(ROUTER_CONFIDENCE_SCORE),
        "RouterConfidenceThreshold": float(ROUTER_CONFIDENCE_THRESHOLD),
        "RouterHardTopN": int(ROUTER_HARD_TOP_N),
        "ManualReviewExcludedCount": int(n_manual_review),
        "ManualReviewExcludedRate": float(manual_review_rate),
        "AutoClassifiedCount": int(n_kept_test),
        "AutoCoverage": float(auto_coverage),
        "HybridAccuracy": float(hybrid_accuracy),

        "AUROC": float(auroc),
        "AP": float(ap),
        "Acc(argmax)": float(acc),

        "FPR_MAX_GLOBAL_TAU": float(FPR_MAX_GLOBAL_TAU),
        "BestTau": float(best_tau),
        "Acc@BestTau": float(best_tau_metrics["Acc"]),
        "FPR_good@BestTau": float(best_tau_metrics["FPR_good"]),
        "TPR_defect@BestTau": float(best_tau_metrics["TPR_defect"]),

        "trained_type_clfs": int(len(bin_clfs) if USE_HIERARCHICAL_CLASSIFICATION else len(clfs)),
        "trained_defect_type_clfs": int(len(def_clfs) if USE_HIERARCHICAL_CLASSIFICATION else 0),
        "fallback_types": int(k_types - (len(bin_clfs) if USE_HIERARCHICAL_CLASSIFICATION else len(clfs))),
        "cluster_min": int(sizes.min()) if sizes.size else 0,
        "cluster_med": float(np.median(sizes)) if sizes.size else 0.0,
        "cluster_max": int(sizes.max()) if sizes.size else 0,
    }

    with open(out_dir / "summary.csv", "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(list(summary.keys()))
        w.writerow([summary[k] for k in summary.keys()])

    return summary

def main():
    OUT_ROOT.mkdir(parents=True, exist_ok=True)

    if K_STEP == 0:
        raise ValueError("K_STEP cannot be 0")
    if (K_MIN <= K_MAX and K_STEP < 0) or (K_MIN >= K_MAX and K_STEP > 0):
        raise ValueError("K_STEP sign does not move from K_MIN toward K_MAX")

    K_TYPES_LIST = list(range(K_MIN, K_MAX + (1 if K_STEP > 0 else -1), K_STEP))

    print(f"[Config] DATA_ROOT={DATA_ROOT}")
    print(f"[Config] GLOBAL_EMB_DIR={GLOBAL_EMB_DIR}")
    print(f"[Config] PATCH_ROOT={PATCH_ROOT}")
    print(f"[Config] PATCH_POOL={PATCH_POOL}, PATCH_TOPK={PATCH_TOPK}")
    print(f"[Config] K sweep: K_MIN={K_MIN}, K_MAX={K_MAX}, K_STEP={K_STEP} -> {K_TYPES_LIST}")
    print(
        f"[Config] CLASSIFIER_BACKEND={CLASSIFIER_BACKEND}, C_VALUES={C_VALUES}, "
        f"MIN_SAMPLES_PER_TYPE={MIN_SAMPLES_PER_TYPE}, USE_BALANCED={USE_BALANCED}"
    )
    print(f"[Config] ALPHAS={ALPHAS}")
    print(f"[Config] FPR_MAX_GLOBAL_TAU={FPR_MAX_GLOBAL_TAU:.2%}")
    print(f"[Config] USE_HIERARCHICAL_CLASSIFICATION={USE_HIERARCHICAL_CLASSIFICATION}")
    print(
        f"[Config] Manual review exclusion: enabled={ENABLE_MANUAL_REVIEW_EXCLUSION}, "
        f"mode={MANUAL_REVIEW_MODE}, score={ROUTER_CONFIDENCE_SCORE}, "
        f"threshold={ROUTER_CONFIDENCE_THRESHOLD}, top_n={ROUTER_HARD_TOP_N}"
    )

    if CLASSIFIER_BACKEND.lower() == "lgbm" and not _HAS_LGB:
        raise RuntimeError("CLASSIFIER_BACKEND='lgbm' but lightgbm is not installed. Run: pip install lightgbm")

    X_global, X_patch, y_mult, meta = load_global_and_patch_features()

    y_bin = (y_mult != 0).astype(int)
    idx = np.arange(len(y_mult))
    tr, te = train_test_split(
        idx,
        test_size=TEST_SIZE,
        random_state=SEED,
        stratify=y_bin
    )

    summary_path = OUT_ROOT / "k_alpha_c_sweep_summary.csv"
    header = [
        "CLASSIFIER_BACKEND", "UseHierarchicalClassification", "K_TYPES", "alpha", "C_VALUE",

        "RouterAccTrain", "RouterAccTest",
        "RouterMeanPurityTrain", "RouterMeanPurityTest",
        "RouterWeightedPurityTrain", "RouterWeightedPurityTest",

        "AUROC", "AP", "Acc(argmax)",
        "AutoCoverage", "HybridAccuracy",
        "ManualReviewExcludedCount", "ManualReviewExcludedRate",

        "RouterConfidenceScore", "RouterConfidenceThreshold", "RouterHardTopN",

        "BestTau", "Acc@BestTau", "FPR_good@BestTau", "TPR_defect@BestTau",

        "MIN_SAMPLES_PER_TYPE", "USE_BALANCED",
        "PATCH_POOL", "PATCH_TOPK",
        "trained_type_clfs", "trained_defect_type_clfs", "fallback_types",
        "cluster_min", "cluster_med", "cluster_max",
        "X_global_dim", "X_patch_dim", "X_cls_dim",
        "is_best_by_hybrid_accuracy"
    ]

    best = None  # (HybridAccuracy, summary)
    all_results = []

    for k_types in K_TYPES_LIST:
        print("\n==============================")
        print(f"==== Sweeping K_TYPES={k_types} ====")
        print("==============================")

        for alpha in ALPHAS:
            X_router, X_cls = build_features_with_alpha(
                X_global,
                X_patch,
                alpha=float(alpha)
            )
            alpha_str = float_to_str(float(alpha))

            for c_value in C_VALUES:
                c_str = float_to_str(float(c_value))
                out_dir = OUT_ROOT / f"k_{int(k_types):d}" / f"alpha_{alpha_str}" / f"C_{c_str}"

                print(f"\n=== Running K_TYPES={k_types} alpha={alpha_str} C={c_str} -> {out_dir} ===")

                summ = run_one_alpha(
                    float(alpha),
                    int(k_types),
                    float(c_value),
                    X_router,
                    X_cls,
                    y_mult,
                    meta,
                    tr,
                    te,
                    out_dir
                )

                all_results.append(summ)

                score_for_selection = summ["HybridAccuracy"]
                if best is None or score_for_selection > best[0]:
                    best = (score_for_selection, summ)

                print(
                    f"K={summ['K_TYPES']} alpha={summ['alpha']:.3f} C={summ['C_VALUE']:.3f}  "
                    f"Hier={summ['UseHierarchicalClassification']}  "
                    f"RouterScore={summ['RouterConfidenceScore']}  "
                    f"RouterAccTest={summ['RouterAccTest']:.4f}  "
                    f"Acc(argmax)={summ['Acc(argmax)']:.4f}  "
                    f"AutoCoverage={summ['AutoCoverage']:.4f}  "
                    f"HybridAccuracy={summ['HybridAccuracy']:.4f}  "
                    f"Excluded={summ['ManualReviewExcludedCount']}"
                )

    with open(summary_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(header)

        for summ in all_results:
            is_best = int(
                best is not None
                and summ["K_TYPES"] == best[1]["K_TYPES"]
                and abs(summ["alpha"] - best[1]["alpha"]) < 1e-12
                and abs(summ["C_VALUE"] - best[1]["C_VALUE"]) < 1e-12
                and summ["UseHierarchicalClassification"] == best[1]["UseHierarchicalClassification"]
                and summ["RouterConfidenceScore"] == best[1]["RouterConfidenceScore"]
            )

            w.writerow([
                summ["CLASSIFIER_BACKEND"],
                summ["UseHierarchicalClassification"],
                summ["K_TYPES"],
                f"{summ['alpha']:.6f}",
                f"{summ['C_VALUE']:.6f}",

                f"{summ['RouterAccTrain']:.6f}",
                f"{summ['RouterAccTest']:.6f}",
                f"{summ['RouterMeanPurityTrain']:.6f}",
                f"{summ['RouterMeanPurityTest']:.6f}",
                f"{summ['RouterWeightedPurityTrain']:.6f}",
                f"{summ['RouterWeightedPurityTest']:.6f}",

                f"{summ['AUROC']:.6f}",
                f"{summ['AP']:.6f}",
                f"{summ['Acc(argmax)']:.6f}",
                f"{summ['AutoCoverage']:.6f}",
                f"{summ['HybridAccuracy']:.6f}",
                summ["ManualReviewExcludedCount"],
                f"{summ['ManualReviewExcludedRate']:.6f}",

                summ["RouterConfidenceScore"],
                f"{summ['RouterConfidenceThreshold']:.6f}",
                summ["RouterHardTopN"],

                f"{summ['BestTau']:.6f}",
                f"{summ['Acc@BestTau']:.6f}",
                f"{summ['FPR_good@BestTau']:.6f}",
                f"{summ['TPR_defect@BestTau']:.6f}",

                summ["MIN_SAMPLES_PER_TYPE"],
                summ["USE_BALANCED"],
                summ["PATCH_POOL"],
                summ["PATCH_TOPK"],
                summ["trained_type_clfs"],
                summ["trained_defect_type_clfs"],
                summ["fallback_types"],
                summ["cluster_min"],
                f"{summ['cluster_med']:.1f}",
                summ["cluster_max"],
                summ["X_global_dim"],
                summ["X_patch_dim"],
                summ["X_cls_dim"],
                is_best,
            ])

    if best is not None:
        print("\n==== Best by Hybrid Accuracy (over K x alpha x C) ====")
        for k, v in best[1].items():
            print(f"{k}: {v}")

        best_csv = OUT_ROOT / "best_config_by_hybrid_accuracy.csv"
        with open(best_csv, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(list(best[1].keys()))
            w.writerow([best[1][k] for k in best[1].keys()])
        print(f"[DONE] Best config saved: {best_csv}")

        best_by_k = {}
        for summ in all_results:
            k = int(summ["K_TYPES"])
            if k not in best_by_k or summ["HybridAccuracy"] > best_by_k[k]["HybridAccuracy"]:
                best_by_k[k] = summ

        best_by_k_csv = OUT_ROOT / "best_alpha_c_per_k_by_hybrid_accuracy.csv"
        with open(best_by_k_csv, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow([
                "K_TYPES", "UseHierarchicalClassification", "RouterConfidenceScore",
                "best_alpha", "best_C_VALUE",
                "Acc(argmax)", "AutoCoverage", "HybridAccuracy",
                "AUROC", "AP", "Acc@BestTau",
                "RouterAccTest", "RouterWeightedPurityTest"
            ])
            for k in sorted(best_by_k.keys()):
                s = best_by_k[k]
                w.writerow([
                    s["K_TYPES"],
                    s["UseHierarchicalClassification"],
                    s["RouterConfidenceScore"],
                    f"{s['alpha']:.6f}",
                    f"{s['C_VALUE']:.6f}",
                    f"{s['Acc(argmax)']:.6f}",
                    f"{s['AutoCoverage']:.6f}",
                    f"{s['HybridAccuracy']:.6f}",
                    f"{s['AUROC']:.6f}",
                    f"{s['AP']:.6f}",
                    f"{s['Acc@BestTau']:.6f}",
                    f"{s['RouterAccTest']:.6f}",
                    f"{s['RouterWeightedPurityTest']:.6f}",
                ])
        print(f"[DONE] Best alpha/C per K saved: {best_by_k_csv}")

    print(f"\n[DONE] Sweep summary saved: {summary_path}")
    print(f"[DONE] Per-run outputs under: {OUT_ROOT}/k_*/alpha_*/C_*/")

if __name__ == "__main__":
